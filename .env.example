# Copy this file to .env and fill in your real values. .env is gitignored.

# From @BotFather
TELEGRAM_BOT_TOKEN=

# From @userinfobot or the getUpdates API — see SETUP.md
TELEGRAM_CHAT_ID=

# Required — your reference number from the consular application
APPLICATION_REFERENCE_NO=

# Required — the jurisdiction dropdown value on the appointment site
# (e.g. Hesse, North Rhine-Westphalia, Rhineland-Palatinate, Saarland)
JURISDICTION=

# Required — the "Select Service" dropdown value under your Service Category
# (e.g. Fresh OCI, Reissue of OCI, Surrender Certificate of Indian Passport)
SERVICE_TYPE=

# Optional — defaults shown
SERVICE_CATEGORY=OCI Services
MAX_MONTHS_TO_CHECK=3
MAX_RESULTS_TO_FIND=3

# Optional — where to persist the "last seen" state between runs.
# Defaults to /data/appointment-state.json (used by the K8s deployment).
# Not needed for local runs or GitHub Actions (the workflow sets its own path).
STATE_FILE_PATH=
